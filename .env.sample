# --- 1. API Configuration ---
API_TITLE=Agentic RAG API
API_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
RAG_API_URL=http://localhost:8000/query
CUDA=true

# --- 2. Neo4j (Graph Database) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<YOUR_NEO4J_PASSWORD>

# --- 3. LiveKit Local Config ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=<YOUR_LIVEKIT_API_KEY>
LIVEKIT_API_SECRET=<YOUR_LIVEKIT_API_SECRET>

# --- 4. Ollama (LLM & Embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
# The main model for generation (Agent)
OLLAMA_MODEL=qwen2.5:7b
# The model used for vector embeddings
EMBEDDING_MODEL=mxbai-embed-large:latest

# --- 5. RAG & Generation Behavior ---
# Default context window for the LLM
MAX_TOKENS=512
# Max retrieval attempts or agent steps
MAX_ITERATIONS=7
# Number of documents to retrieve initially
TOP_K_RETRIEVAL=3

# --- 6. Ingestion Settings (Chunking) ---
# Tokens per chunk (used by ingest_multi_docs.py)
CHUNK_TOKENS=512
# Overlap between chunks
CHUNK_OVERLAP=128
# Batch size for embedding generation (speed vs RAM)
EMBEDDING_BATCH_SIZE=32

# --- Graph Specific Settings ---
GRAPH_CHUNK_TOKENS=256  # Smaller chunks for Entity Extraction (precision)
GRAPH_CHUNK_OVERLAP=32

# --- 7. Watcher Settings ---
# The folder where you drop files to be ingested
WATCH_DIR=knowledge

# --- 8. File Paths & Databases ---
# Vector Store (FAISS)
FAISS_INDEX_PATH=backend/db/vector_data/knowledge_faiss.index
FAISS_META_PATH=backend/db/vector_data/knowledge_meta.jsonl
META_DB_PATH=backend/db/vector_data/metadata_store.db

# Memory & Cache
MEMORY_DB_PATH=backend/db/memory/memory_store.sqlite
EMBEDDING_CACHE_DB=backend/db/embedding_cache/embed_cache.sqlite
# How many chat turns to keep in active memory
MEMORY_MAX_TURNS=100

# --- 9. Reranker Settings ---
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BACKEND=cross-encoder
RERANKER_BATCH_SIZE=8
RERANKER_NORMALIZE=sigmoid
# How many raw results to fetch before reranking (must be > TOP_K_RETRIEVAL)
RERANKER_INITIAL_K=14

SEMANTIC_CACHE_MODEL=BAAI/bge-large-en-v1.5
SEMANTIC_CACHE_THRESHOLD=0.80

# --- 10. Frontend ---
CHAINLIT_ENABLED=true